algoritmo "soma"
// F9: Executa o cµdigo

// Autor: Thiago
// Disciplina: LOPAL
// Data: 07/04/2026
var
c, f: real
inicio
      // Entrada
      escreva ("Informe a temperatura em ¤C: ")
      leia (c)
      
      // Processo
      f <- 9 * c / 5 + 32
      
      // SaÚda
      escreva ("Temperatura em ¤F: ", f)
fimalgoritmo
