algoritmo "temperatura"
// F9: Executa o código

// Autor: Thiago
// Disciplina: LOPAL
// Data: 07/04/2026
var
c, f: real
inicio
      // Entrada
      escreva ("Informe a temperatura em şC: ")
      leia (c)
      
      // Processo
      f <- 9 * c / 5 + 32
      
      // Saída
      escreva ("Temperatura em şF: ", f)
fimalgoritmo
