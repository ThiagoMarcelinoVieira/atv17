algoritmo "soma"
// F9: Executa o código

// Autor: Thiago
// Disciplina: LOPAL
// Data: 07/04/2026
var
n1, n2, total: real
inicio
      // Entrada
      escreva ("Informe o primeiro número: ")
      leia (n1)
      
      escreva ("Informe o segundo número: ")
      leia (n2)
      
      // Processo
      total <- n1 + n2
      
      // Saída
      escreva ("Total: ", total)
fimalgoritmo
